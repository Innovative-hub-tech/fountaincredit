# Client-side (exposed to the browser — must be prefixed VITE_)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side only (used by TanStack Start server functions, NOT exposed to the browser)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Required for admin/server-side operations that bypass RLS (src/integrations/supabase/client.server.ts)
# Get this from Supabase Dashboard → Project Settings → API → service_role key
# NEVER expose this with a VITE_ prefix, never commit it, never send it to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
